# Supabase — copy to webapp/.env.local and mobile/.env
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase service role (server-only, never expose to client)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Public site URL — used for sitemap, RSS, OG tags, JSON-LD
NEXT_PUBLIC_SITE_URL=https://opensteps.10na.city

# Resend — transactional email (guide submitted, guide published, etc.)
# Get your API key from resend.com/api-keys
RESEND_API_KEY=re_your_api_key_here
